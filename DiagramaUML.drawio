        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;classDiagram\n  class Persona {\n    +id_persona (str)\n    +nombre (str)\n    +email (str)\n    +descripcion() str\n  }\n  class Estudiante {\n    +legajo (str)\n    +descripcion() str\n  }\n  class Docente {\n    +departamento (str)\n    +descripcion() str\n  }\n  class Curso {\n    +id_curso (str)\n    +nombre (str)\n    +id_docente (str)\n    +cupo (int)\n    +descripcion() str\n  }\n  class Inscripcion {\n    +id_inscripcion (str)\n    +id_estudiante (str)\n    +id_curso (str)\n    +fecha (str)\n    +descripcion() str\n  }\n  class EstrategiaBusqueda {\n    &lt;&lt;abstract&gt;&gt;\n    +coincide(obj, consulta) bool\n  }\n  class BuscarPorId {\n    +coincide(obj, consulta) bool\n  }\n  class BuscarPorNombre {\n    +coincide(obj, consulta) bool\n  }\n  class BuscarPorEmail {\n    +coincide(obj, consulta) bool\n  }\n  class Buscador {\n    -_estrategia EstrategiaBusqueda\n    +set_estrategia(e EstrategiaBusqueda) void\n    +buscar(items list, consulta str) list\n  }\n  class RepositorioAcademico {\n    +estudiantes list\n    +docentes list\n    +cursos list\n    +inscripciones list\n    +add_estudiante(e Estudiante)\n    +add_docente(d Docente)\n    +add_curso(c Curso)\n    +inscribir(i Inscripcion)\n    +eliminar_estudiante(id str)\n    +eliminar_docente(id str)\n    +eliminar_curso(id str)\n    +eliminar_inscripcion(id str)\n    +cursos_de_estudiante(id str) list\n    +cursos_de_docente(id str) list\n    +next_id_estudiante() str\n    +next_id_docente() str\n    +next_id_curso() str\n    +next_legajo_estudiante() str\n  }\n  class AlmacenamientoJson {\n    -_path Path\n    +cargar() RepositorioAcademico\n    +guardar(repo RepositorioAcademico) void\n  }\n\n  Persona &lt;|-- Estudiante\n  Persona &lt;|-- Docente\n  Docente \&quot;1\&quot; &lt;-- \&quot;0..*\&quot; Curso : id_docente\n  Estudiante \&quot;1\&quot; &lt;-- \&quot;0..*\&quot; Inscripcion : id_estudiante\n  Curso \&quot;1\&quot; &lt;-- \&quot;0..*\&quot; Inscripcion : id_curso\n  \n  EstrategiaBusqueda &lt;|-- BuscarPorId\n  EstrategiaBusqueda &lt;|-- BuscarPorNombre\n  EstrategiaBusqueda &lt;|-- BuscarPorEmail\n  Buscador --&gt; EstrategiaBusqueda : usa\n\n  RepositorioAcademico o-- Estudiante : contiene\n  RepositorioAcademico o-- Docente : contiene\n  RepositorioAcademico o-- Curso : contiene\n  RepositorioAcademico o-- Inscripcion : contiene\n  AlmacenamientoJson ..&gt; RepositorioAcademico : carga/guarda\n\n  style Persona fill:#fff9c4\n  style Estudiante fill:#fff9c4\n  style Docente fill:#fff9c4\n  style Curso fill:#fff9c4\n  style Inscripcion fill:#fff9c4\n  style EstrategiaBusqueda fill:#fce4ec\n  style BuscarPorId fill:#fce4ec\n  style BuscarPorNombre fill:#fce4ec\n  style BuscarPorEmail fill:#fce4ec\n  style Buscador fill:#fce4ec\n  style RepositorioAcademico fill:#eeeeee\n  style AlmacenamientoJson fill:#eeeeee&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="27L-6F7F2VTF8kXPtnZ8-1">
